➜ Vulnerable Code Example

<?php 
    $messages = $db->query("SELECT * FROM messages");
    if ($messages) {
        while ($row = $messages->fetch(PDO::FETCH_ASSOC)) {
            echo "<div>" . $row['message'] . "</div>";
        }
    }
?>

➜ Secure Code Example

<?php 
    $messages = $db->query("SELECT * FROM messages");
    if ($messages) {
        while ($row = $messages->fetch(PDO::FETCH_ASSOC)) {
            echo "<div>" .  htmlspecialchars($row['message']) . "</div>";
        }
    }
?>


